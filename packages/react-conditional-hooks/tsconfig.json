{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist"
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["**/node_modules/**", "dist", "**/*.test.tsx"]
}
